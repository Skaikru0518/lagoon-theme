  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#5A6573",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#9B93C4"
      }
    },
    {
      "scope": [
        "keyword.control.return",
        "keyword.control.flow.return",
        "keyword.control.trycatch",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#63A98C"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.definition.method entity.name.function",
        "entity.name.function.member",
        "meta.method-call entity.name.function",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#6B9AC2"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "meta.property.object",
        "support.variable.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "variable.other.object.access"
      ],
      "settings": {
        "foreground": "#BCC4CD"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#69AE8F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "support.constant"
      ],
      "settings": {
        "foreground": "#63AC8E"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.type.class",
        "meta.type.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#73B0B5"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.constant",
        "meta.definition.variable entity.name",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#8E94A6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.parameter.function",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#BCC4CD"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.super",
        "constant.language.this"
      ],
      "settings": {
        "foreground": "#73B4C2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.variable",
        "support.variable.dom",
        "support.variable.property.dom",
        "variable.language.window",
        "variable.other.global"
      ],
      "settings": {
        "foreground": "#BCC4CD",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arrow",
        "storage.type.function.arrow",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "punctuation.definition.parameters",
        "punctuation.definition.block",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#9AA2AC"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#88A496"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A99BE6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#6B9AC2"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#73B4C2"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#6B9AC2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#88A496", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#A99BE6", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#69AE8F" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#5FC2D6", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E66A6A" }
    },
    {
      "scope": ["comment.documentation", "comment.block.documentation"],
      "settings": { "foreground": "#69737F", "fontStyle": "italic" }
    }
  ],
  "semanticTokenColors": {
    "variable.defaultLibrary": { "foreground": "#BCC4CD", "fontStyle": "" },
    "property.defaultLibrary": { "foreground": "#BCC4CD" },
    "property": { "foreground": "#BCC4CD" },
    "variable.readonly": { "foreground": "#8E94A6" },
    "parameter": { "foreground": "#BCC4CD" }
  }
}
