    "editorLink.activeForeground": "#1F8FA8"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#8AA0A0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#0E8C7A"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.definition.method entity.name.function",
        "entity.name.function.member"
      ],
      "settings": {
        "foreground": "#2476B8"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "meta.property.object",
        "support.variable.property",
        "variable.other.object.property",
        "meta.method-call entity.name.function",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#7C5CD4"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#1E9E78"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "support.constant"
      ],
      "settings": {
        "foreground": "#0E9E7E"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.type.class",
        "meta.type.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#1A8E83"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable entity.name"
      ],
      "settings": {
        "foreground": "#2A3B3E"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#3A4D50"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.super",
        "support.variable",
        "constant.language.this"
      ],
      "settings": {
        "foreground": "#1F8FA8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace",
        "punctuation.definition.parameters"
      ],
      "settings": {
        "foreground": "#5E7472"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#0E8C7A"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7C5CD4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#2476B8"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#1F8FA8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#2476B8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#0E8C7A", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#7C5CD4", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#1E9E78" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#1F8FA8", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#CC4B4B" }
    },
    {
      "scope": ["comment.documentation", "comment.block.documentation"],
      "settings": { "foreground": "#7C9290", "fontStyle": "italic" }
    }
  ]
}
