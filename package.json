{
  "name": "lagoon-theme",
  "displayName": "Lagoon",
  "description": "Aesthetic teal-to-lavender theme with Dark and Light variants, inspired by gradient code-screenshot vibes.",
  "version": "1.0.6",
  "publisher": "dante",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dante/lagoon-theme"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "teal",
    "dark",
    "light"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Lagoon Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/lagoon-dark-color-theme.json"
      },
      {
        "label": "Lagoon Light",
        "uiTheme": "vs",
        "path": "./themes/lagoon-light-color-theme.json"
      }
    ]
  },
  "files": [
    "themes",
    "README.md",
    "LICENSE.md",
    "package.json"
  ]
}
